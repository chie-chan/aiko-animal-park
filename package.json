{
  "name": "aiko-animal-park",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:aiko": "vite --mode aiko --port 5180",
    "dev:mirror": "vite --port 5181",
    "build": "vite build",
    "build:aiko": "vite build --mode aiko",
    "preview": "vite preview",
    "sync:works-gallery": "node scripts/sync-firebase-gallery-manifest-to-park.mjs",
    "check:sns-worker": "node --check workers/sns-post-worker/src/index.mjs && node --check workers/sns-post-worker/scripts/deploy-dry-run.mjs && node --check workers/sns-post-worker/scripts/deploy-live.mjs && node --check workers/sns-post-worker/scripts/deploy-safe.mjs && node workers/sns-post-worker/test/sns-post-worker.test.mjs",
    "deploy:sns-worker:dry-run": "node workers/sns-post-worker/scripts/deploy-dry-run.mjs",
    "deploy:sns-worker:live": "node workers/sns-post-worker/scripts/deploy-live.mjs",
    "deploy:sns-worker:safe": "node workers/sns-post-worker/scripts/deploy-safe.mjs",
    "audit:server": "node scripts/catalog-audit-editor-server.cjs"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wrangler": "^4.100.0"
  }
}
